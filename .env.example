# ---- MongoDB (Atlas free tier is fine) ----
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net
MONGODB_DB=job_apply

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
# Any model your key can access. gpt-4o-mini is cheap; gpt-4o writes better email copy.
LLM_MODEL=gpt-4o-mini

# ---- Gmail (APP PASSWORD, not your normal password; requires 2-Step Verification) ----
# Create one at https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Which alert senders to read (comma-separated; matched as substrings of the From address)
ALERT_SENDERS=jobs-noreply@linkedin.com,jobalerts-noreply@linkedin.com,info@naukri.com,alert@indeed.com,noreply@indeed.com

# Absolute path to the resume PDF that gets attached to every email
RESUME_PATH=/absolute/path/to/your_resume.pdf

# How often the worker reads alert emails
CRAWL_INTERVAL_HOURS=2
